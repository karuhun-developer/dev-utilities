---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	keywords?: string;
	canonicalUrl?: string;
}

const { 
	title, 
	description = "A collection of fast, browser-based tools for developers. Everything runs locally in your browser to ensure privacy and speed.",
	keywords = "developer tools, utilities, random string generator, uuid generator, hash generator",
	canonicalUrl = Astro.url.href
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="sitemap" href="/sitemap-index.xml" />
		
		<!-- SEO Meta Tags -->
		<title>{title} - Dev Utils</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<link rel="canonical" href={canonicalUrl} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={`${title} - Dev Utils`} />
		<meta property="og:description" content={description} />
		
		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalUrl} />
		<meta property="twitter:title" content={`${title} - Dev Utils`} />
		<meta property="twitter:description" content={description} />
	</head>
	<body class="bg-zinc-50 text-zinc-900 font-sans antialiased min-h-screen flex flex-col">
		<header class="bg-white border-b border-zinc-200 py-4 px-6 sticky top-0 z-10">
			<div class="max-w-7xl mx-auto flex items-center justify-between">
				<a href="/" class="flex items-center gap-3">
					<img src="/logo.png" alt="Karuhun Logo" class="h-8 w-auto" />
					<span class="text-xl font-bold tracking-tight">Karuhun <span class="font-normal text-zinc-500">DevUtils</span></span>
				</a>
				<div class="flex items-center gap-4">
					<a href="https://github.com/karuhun-developer/dev-utilities" target="_blank" rel="noopener noreferrer" class="text-zinc-500 hover:text-zinc-900 transition-colors" title="View on GitHub">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
					</a>
					<div class="h-4 w-px bg-zinc-300 hidden sm:block"></div>
					<a href="https://karuhundeveloper.com" target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors flex items-center gap-1.5">
						<span class="hidden sm:inline">by</span>
						<span class="font-medium text-zinc-700 hover:text-zinc-900">karuhundeveloper.com</span>
						<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-zinc-400" viewBox="0 0 20 20" fill="currentColor">
							<path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
							<path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
						</svg>
					</a>
				</div>
			</div>
		</header>
		
		<div class="flex-1 max-w-7xl mx-auto w-full flex flex-col md:flex-row">
			<aside class="w-full md:w-64 border-r border-zinc-200 bg-zinc-50/50 flex-shrink-0" x-data="sidebarSearch()" x-init="init()">

				<!-- Search -->
				<div class="p-4 border-b border-zinc-200">
					<div class="relative">
						<svg xmlns="http://www.w3.org/2000/svg" class="absolute left-2.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-zinc-400 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
						</svg>
						<input
							type="search"
							id="sidebar-search"
							x-model="query"
							@input="search()"
							placeholder="Search tools..."
							autocomplete="off"
							class="w-full pl-8 pr-3 py-2 text-sm bg-white border border-zinc-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-zinc-300 focus:border-transparent placeholder-zinc-400 transition-all"
						/>
						<button
							x-show="query.length > 0"
							@click="query = ''; search();"
							style="display:none;"
							class="absolute right-2.5 top-1/2 -translate-y-1/2 text-zinc-400 hover:text-zinc-600"
						>
							<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
						</button>
					</div>
				</div>

				<!-- Nav content -->
				<nav class="p-3 space-y-1 overflow-y-auto" style="max-height: calc(100vh - 130px);">

					<!-- Search results (flat list, shown only when searching) -->
					<div x-show="query.length > 0" style="display:none;">
						<p class="text-xs font-semibold text-zinc-400 uppercase tracking-wider px-2 py-1 mb-1">
							Results (<span x-text="results.length"></span>)
						</p>
						<template x-if="results.length === 0">
							<p class="text-xs text-zinc-400 italic px-2 py-3">No tools found.</p>
						</template>
						<template x-for="item in results" :key="item.href">
							<a
								:href="item.href"
								class="flex items-center gap-2 px-3 py-2 text-sm font-medium rounded-lg hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors"
							>
								<span class="text-base leading-none" x-text="item.icon"></span>
								<span x-text="item.label"></span>
							</a>
						</template>
					</div>

					<!-- Grouped nav (shown when not searching) -->
					<div x-show="query.length === 0">
						<template x-for="group in groups" :key="group.label">
							<div class="mb-3">
								<p class="text-xs font-semibold text-zinc-400 uppercase tracking-wider px-2 py-1 mb-0.5 flex items-center gap-1.5">
									<span x-text="group.emoji"></span>
									<span x-text="group.label"></span>
								</p>
								<template x-for="item in group.items" :key="item.href">
									<a
										:href="item.href"
										class="block px-3 py-2 text-sm font-medium rounded-lg hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors"
										x-text="item.label"
									></a>
								</template>
							</div>
						</template>
					</div>

				</nav>
			</aside>

			<main class="flex-1 p-6 md:p-10 bg-white">
				<slot />
			</main>
		</div>

		<script is:inline>
			document.addEventListener('alpine:init', () => {
				Alpine.data('sidebarSearch', () => ({
					query: '',
					results: [],
					groups: [
						{
							emoji: '🖼️',
							label: 'Images & Assets',
							items: [
								{ href: '/remove-bg',       label: 'Remove Background',    icon: '🪄', tags: 'ai background remove erase photo' },
								{ href: '/image-converter', label: 'Image Converter',       icon: '🔄', tags: 'convert jpg png webp bmp ico gif tiff avif format batch' },
								{ href: '/resize-image',    label: 'Resize Image',          icon: '📐', tags: 'resize dimensions width height' },
								{ href: '/scale-image',     label: 'Scale Image',           icon: '🔍', tags: 'scale percentage zoom' },
								{ href: '/grayscale-image', label: 'Grayscale Image',       icon: '⬛', tags: 'grayscale black white filter' },
								{ href: '/image-base64',    label: 'Image ⇄ Base64',        icon: '📦', tags: 'base64 encode decode image' },
								{ href: '/trim-image',      label: 'Trim Image Padding',    icon: '✂️', tags: 'trim crop whitespace padding transparent border remove' },
								{ href: '/image-to-svg',    label: 'Image to SVG Vector',   icon: '✒️', tags: 'image to svg vector raster convert trace vectorizer' },
								{ href: '/merge-images',    label: 'Merge Images',          icon: '🧩', tags: 'merge stitch join combine photo side vertical horizontal' },
								{ href: '/placeholder-generator', label: 'Placeholder Generator', icon: '🖼️', tags: 'placeholder dummy image mock svg png webp base64' },
							],
						},
						{
							emoji: '📝',
							label: 'Text Tools',
							items: [
								{ href: '/word-counter',    label: 'Word Counter',          icon: '🔢', tags: 'word count character sentence paragraph reading time' },
								{ href: '/text-template',   label: 'Text Template',         icon: '📋', tags: 'template variable placeholder text editor' },
								{ href: '/url-encode-decode', label: 'URL Encode / Decode', icon: '🔗', tags: 'url encode decode percent encoding' },
							],
						},
						{
							emoji: '📦',
							label: 'Data & Format',
							items: [
								{ href: '/json-formatter',    label: 'JSON Formatter',      icon: '{ }', tags: 'json format prettify validate minify' },
								{ href: '/json-csv-converter', label: 'JSON ⇄ CSV',         icon: '📊', tags: 'json csv convert table data' },
								{ href: '/timestamp-converter', label: 'Timestamp Converter', icon: '🕐', tags: 'unix timestamp date time convert utc' },
							],
						},
						{
							emoji: '🔐',
							label: 'Security',
							items: [
								{ href: '/hash-generator',  label: 'Hash Gen & Validate',  icon: '#️⃣', tags: 'hash sha md5 sha256 validate checksum' },
								{ href: '/bcrypt-generator', label: 'Bcrypt Generator',     icon: '🔒', tags: 'bcrypt hash password salt rounds' },
							],
						},
						{
							emoji: '⚙️',
							label: 'Generators',
							items: [
								{ href: '/random-string',  label: 'Random String',          icon: '🎲', tags: 'random string password token key generate' },
								{ href: '/uuid-generator', label: 'UUID Generator',          icon: '🆔', tags: 'uuid guid v4 unique identifier' },
							],
						},
						{
							emoji: '📷',
							label: 'QR & Barcode',
							items: [
								{ href: '/qr-generator',     label: 'QR Generator',         icon: '⬛', tags: 'qr code generate url text download' },
								{ href: '/qr-reader',        label: 'QR Reader',             icon: '📷', tags: 'qr code scan read decode camera upload' },
								{ href: '/barcode-generator', label: 'Barcode Generator',   icon: '▐▌', tags: 'barcode code128 ean upc generate' },
							],
						},
					],

					get allItems() {
						return this.groups.flatMap(g => g.items.map(item => ({ ...item, group: g.label })));
					},

					init() {},

					search() {
						const q = this.query.trim().toLowerCase();
						if (!q) { this.results = []; return; }
						this.results = this.allItems.filter(item =>
							item.label.toLowerCase().includes(q) ||
							(item.tags && item.tags.toLowerCase().includes(q))
						);
					},
				}));
			});
		</script>
	</body>
</html>