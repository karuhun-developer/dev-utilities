---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	keywords?: string;
	canonicalUrl?: string;
}

const { 
	title, 
	description = "A collection of fast, browser-based tools for developers. Everything runs locally in your browser to ensure privacy and speed.",
	keywords = "developer tools, utilities, random string generator, uuid generator, hash generator",
	canonicalUrl = Astro.url.href
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="sitemap" href="/sitemap-index.xml" />
		
		<!-- SEO Meta Tags -->
		<title>{title} - Dev Utils</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<link rel="canonical" href={canonicalUrl} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={`${title} - Dev Utils`} />
		<meta property="og:description" content={description} />
		
		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalUrl} />
		<meta property="twitter:title" content={`${title} - Dev Utils`} />
		<meta property="twitter:description" content={description} />
	</head>
	<body class="bg-zinc-50 text-zinc-900 font-sans antialiased min-h-screen flex flex-col">
		<header class="bg-white border-b border-zinc-200 py-4 px-6 sticky top-0 z-10">
			<div class="max-w-7xl mx-auto flex items-center justify-between">
				<a href="/" class="flex items-center gap-3">
					<img src="/logo.png" alt="Karuhun Logo" class="h-8 w-auto" />
					<span class="text-xl font-bold tracking-tight">Karuhun <span class="font-normal text-zinc-500">DevUtils</span></span>
				</a>
				<div class="flex items-center gap-4">
					<a href="https://github.com/karuhun-developer/dev-utilities" target="_blank" rel="noopener noreferrer" class="text-zinc-500 hover:text-zinc-900 transition-colors" title="View on GitHub">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
					</a>
					<div class="h-4 w-px bg-zinc-300 hidden sm:block"></div>
					<a href="https://karuhundeveloper.com" target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors flex items-center gap-1.5">
						<span class="hidden sm:inline">by</span>
						<span class="font-medium text-zinc-700 hover:text-zinc-900">karuhundeveloper.com</span>
						<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-zinc-400" viewBox="0 0 20 20" fill="currentColor">
							<path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
							<path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
						</svg>
					</a>
				</div>
			</div>
		</header>
		
		<div class="flex-1 max-w-7xl mx-auto w-full flex flex-col md:flex-row">
			<aside class="w-full md:w-64 border-r border-zinc-200 bg-zinc-50/50 p-6">
				<nav class="space-y-1">
					<p class="text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-3">Utilities</p>
					<a href="/remove-bg" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">Remove Background</a>
					<a href="/image-converter" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">Image Converter</a>
					<a href="/resize-image" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">Resize Image</a>
					<a href="/scale-image" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">Scale Image</a>
					<a href="/grayscale-image" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">Grayscale Image</a>
					<a href="/image-base64" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">Image Base64</a>
					<a href="/random-string" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">Random String</a>
					<a href="/uuid-generator" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">UUID Generator</a>
					<a href="/hash-generator" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">Hash Gen & Validate</a>
					<a href="/bcrypt-generator" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">Bcrypt Generator</a>
					<a href="/json-formatter" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">JSON Formatter</a>
					<a href="/json-csv-converter" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">JSON ⇄ CSV</a>
					<a href="/timestamp-converter" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">Timestamp Converter</a>
					<a href="/url-encode-decode" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">URL Encode / Decode</a>
					<a href="/text-template" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">Text Template</a>
					<a href="/qr-generator" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">QR Generator</a>
					<a href="/qr-reader" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">QR Reader</a>
					<a href="/barcode-generator" class="block px-3 py-2 text-sm font-medium rounded-md hover:bg-zinc-100 hover:text-zinc-900 text-zinc-600 transition-colors">Barcode Generator</a>
				</nav>
			</aside>
			<main class="flex-1 p-6 md:p-10 bg-white">
				<slot />
			</main>
		</div>
	</body>
</html>