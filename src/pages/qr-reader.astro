---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="QR Code Reader"
	description="Scan and decode QR codes from uploaded images or your device camera directly in the browser. Free and private — no data leaves your device."
	keywords="qr code reader, qr scanner, decode qr code, qr code from image, scan qr code online"
>
	<div class="max-w-4xl" x-data="qrReaderApp()">
		<h1 class="text-2xl font-bold text-zinc-900 mb-2">QR Code Reader</h1>
		<p class="text-zinc-600 mb-8">Upload an image or use your camera to decode a QR code. Processed entirely in your browser.</p>

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

			<!-- Input -->
			<div class="space-y-5">
				<!-- Tab: Upload vs Camera -->
				<div class="flex border border-zinc-200 rounded-lg overflow-hidden text-sm">
					<button @click="mode = 'upload'; stopCamera()" :class="mode === 'upload' ? 'bg-zinc-900 text-white' : 'bg-white text-zinc-600 hover:bg-zinc-50'" class="flex-1 py-2 font-medium transition-colors">
						📁 Upload Image
					</button>
					<button @click="mode = 'camera'; startCamera()" :class="mode === 'camera' ? 'bg-zinc-900 text-white' : 'bg-white text-zinc-600 hover:bg-zinc-50'" class="flex-1 py-2 font-medium transition-colors">
						📷 Camera
					</button>
				</div>

				<!-- Upload Mode -->
				<div x-show="mode === 'upload'" class="space-y-4">
					<div class="flex justify-center px-6 pt-5 pb-6 border-2 border-zinc-300 border-dashed rounded-lg hover:bg-zinc-50 transition-colors">
						<div class="space-y-1 text-center">
							<svg class="mx-auto h-10 w-10 text-zinc-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
								<path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
							</svg>
							<div class="flex text-sm text-zinc-600 justify-center">
								<label for="qr-file" class="cursor-pointer font-medium text-blue-600 hover:text-blue-500">
									<span>Upload image</span>
									<input id="qr-file" type="file" accept="image/*" class="sr-only" @change="readFromFile">
								</label>
								<p class="pl-1">or drag and drop</p>
							</div>
							<p class="text-xs text-zinc-500">PNG, JPG, WEBP, GIF</p>
						</div>
					</div>
					<div x-show="previewSrc" style="display:none;" class="bg-zinc-50 border border-zinc-200 rounded-lg p-2 flex justify-center">
						<img :src="previewSrc" class="max-h-48 object-contain rounded" alt="Uploaded image">
					</div>
				</div>

				<!-- Camera Mode -->
				<div x-show="mode === 'camera'" style="display:none;" class="space-y-3">
					<div class="relative bg-black rounded-lg overflow-hidden aspect-square flex items-center justify-center">
						<video id="qr-video" autoplay playsinline muted class="w-full h-full object-cover"></video>
						<div x-show="!cameraActive" class="absolute inset-0 flex items-center justify-center text-zinc-400 text-sm">Starting camera...</div>
						<!-- Scanning overlay -->
						<div x-show="cameraActive" class="absolute inset-8 border-2 border-white/60 rounded-lg" style="display:none;">
							<div class="absolute top-0 left-0 w-6 h-6 border-t-4 border-l-4 border-white rounded-tl"></div>
							<div class="absolute top-0 right-0 w-6 h-6 border-t-4 border-r-4 border-white rounded-tr"></div>
							<div class="absolute bottom-0 left-0 w-6 h-6 border-b-4 border-l-4 border-white rounded-bl"></div>
							<div class="absolute bottom-0 right-0 w-6 h-6 border-b-4 border-r-4 border-white rounded-br"></div>
						</div>
					</div>
					<p x-show="cameraActive" class="text-xs text-zinc-400 text-center" style="display:none;">Point your camera at a QR code — it will scan automatically</p>
					<canvas id="qr-cam-canvas" style="display:none;"></canvas>
				</div>
			</div>

			<!-- Result -->
			<div class="space-y-4">
				<div class="bg-zinc-50 border border-zinc-200 rounded-lg p-5 min-h-[280px] flex flex-col">
					<span class="text-xs font-bold text-zinc-500 uppercase tracking-wider mb-3">Decoded Result</span>

					<div x-show="scanning" class="flex-1 flex items-center justify-center" style="display:none;">
						<div class="flex items-center gap-2 text-zinc-500 text-sm">
							<svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
							Scanning...
						</div>
					</div>

					<div x-show="result" style="display:none;" class="flex-1 flex flex-col gap-3">
						<div class="bg-white border border-zinc-200 rounded p-3 font-mono text-sm break-all text-zinc-900 flex-1" x-text="result"></div>
						<div class="flex gap-2">
							<button @click="copyResult()" class="flex-1 px-3 py-1.5 bg-zinc-900 text-white rounded text-xs font-medium hover:bg-zinc-800 transition-colors" x-text="copied ? 'Copied!' : 'Copy Text'"></button>
							<a x-show="isUrl" :href="result" target="_blank" rel="noopener noreferrer" class="flex-1 px-3 py-1.5 bg-blue-600 text-white rounded text-xs font-medium hover:bg-blue-700 transition-colors text-center" style="display:none;">
								Open URL ↗
							</a>
						</div>
					</div>

					<div x-show="errorMsg" class="flex-1 flex items-center justify-center" style="display:none;">
						<p class="text-sm text-red-500 text-center" x-text="errorMsg"></p>
					</div>

					<div x-show="!scanning && !result && !errorMsg" class="flex-1 flex items-center justify-center">
						<p class="text-sm text-zinc-400 italic text-center">Upload an image or use camera to scan a QR code</p>
					</div>
				</div>
			</div>
		</div>
	</div>

	<script is:inline>
		(function() {
			const s = document.createElement('script');
			s.src = 'https://cdn.jsdelivr.net/npm/jsqr@1.4.0/dist/jsQR.js';
			document.head.appendChild(s);
		})();

		document.addEventListener('alpine:init', () => {
			Alpine.data('qrReaderApp', () => ({
				mode: 'upload',
				previewSrc: '',
				result: '',
				errorMsg: '',
				scanning: false,
				copied: false,
				cameraActive: false,
				_stream: null,
				_rafId: null,

				get isUrl() {
					try { new URL(this.result); return true; } catch { return false; }
				},

				readFromFile(e) {
					const file = e.target.files[0];
					if (!file) return;
					const reader = new FileReader();
					reader.onload = (ev) => {
						this.previewSrc = ev.target.result;
						this.decodeFromDataUrl(ev.target.result);
					};
					reader.readAsDataURL(file);
				},

				decodeFromDataUrl(dataUrl) {
					if (!window.jsQR) {
						this.errorMsg = 'QR library not loaded yet. Please try again.';
						return;
					}
					this.result = '';
					this.errorMsg = '';
					this.scanning = true;

					const img = new Image();
					img.onload = () => {
						const canvas = document.createElement('canvas');
						canvas.width = img.width;
						canvas.height = img.height;
						const ctx = canvas.getContext('2d');
						ctx.drawImage(img, 0, 0);
						const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
						const code = jsQR(imageData.data, imageData.width, imageData.height);
						this.scanning = false;
						if (code) {
							this.result = code.data;
						} else {
							this.errorMsg = 'No QR code found in the image. Try a clearer or higher-resolution photo.';
						}
					};
					img.src = dataUrl;
				},

				async startCamera() {
					this.result = '';
					this.errorMsg = '';
					try {
						this._stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
						const video = document.getElementById('qr-video');
						video.srcObject = this._stream;
						await video.play();
						this.cameraActive = true;
						this.scanLoop();
					} catch(e) {
						this.errorMsg = 'Camera access denied or not available: ' + e.message;
					}
				},

				scanLoop() {
					const video = document.getElementById('qr-video');
					const canvas = document.getElementById('qr-cam-canvas');
					if (!video || !canvas || !this.cameraActive) return;

					if (video.readyState === video.HAVE_ENOUGH_DATA) {
						canvas.width = video.videoWidth;
						canvas.height = video.videoHeight;
						const ctx = canvas.getContext('2d');
						ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
						const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
						if (window.jsQR) {
							const code = jsQR(imageData.data, imageData.width, imageData.height);
							if (code && code.data !== this.result) {
								this.result = code.data;
							}
						}
					}
					this._rafId = requestAnimationFrame(() => this.scanLoop());
				},

				stopCamera() {
					this.cameraActive = false;
					if (this._rafId) cancelAnimationFrame(this._rafId);
					if (this._stream) {
						this._stream.getTracks().forEach(t => t.stop());
						this._stream = null;
					}
				},

				copyResult() {
					if (!this.result) return;
					navigator.clipboard.writeText(this.result);
					this.copied = true;
					setTimeout(() => { this.copied = false; }, 2000);
				}
			}));
		});
	</script>
</Layout>
