---
import Layout from '../layouts/Layout.astro';
---

<Layout 
	title="Developer Utilities"
	description="Free, fast, and privacy-friendly utilities for developers. Generate UUIDs, random strings, hashes and more directly in your browser without server tracking."
	keywords="developer utilities, dev tools, online uuid generator, hash generator, random string"
>
	<div class="max-w-2xl">
		<h1 class="text-3xl font-bold text-zinc-900 mb-4">Developer Utilities</h1>
		<p class="text-zinc-600 mb-8 leading-relaxed">
			A collection of fast, browser-based tools for developers. Everything runs locally in your browser to ensure privacy and speed.
		</p>
		
		<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
			<a href="/random-string" class="block p-6 bg-zinc-50 border border-zinc-200 rounded-xl hover:border-zinc-400 hover:shadow-sm transition-all group">
				<h3 class="font-semibold text-zinc-900 mb-1 group-hover:text-zinc-700">Random String Generator</h3>
				<p class="text-sm text-zinc-500">Generate secure random strings for passwords, tokens, or keys.</p>
			</a>
			<a href="/uuid-generator" class="block p-6 bg-zinc-50 border border-zinc-200 rounded-xl hover:border-zinc-400 hover:shadow-sm transition-all group">
				<h3 class="font-semibold text-zinc-900 mb-1 group-hover:text-zinc-700">UUID Generator</h3>
				<p class="text-sm text-zinc-500">Generate universally unique identifiers (v4).</p>
			</a>
			<a href="/hash-generator" class="block p-6 bg-zinc-50 border border-zinc-200 rounded-xl hover:border-zinc-400 hover:shadow-sm transition-all group">
				<h3 class="font-semibold text-zinc-900 mb-1 group-hover:text-zinc-700">Hash Generator & Validator</h3>
				<p class="text-sm text-zinc-500">Compute SHA-1, SHA-256, SHA-384, SHA-512 hashes and validate hashes.</p>
			</a>
		</div>
	</div>
</Layout>
