---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Word Counter"
	description="Free online word counter tool. Count words, characters, sentences, paragraphs, spaces, lines, and estimate reading & speaking time instantly in your browser."
	keywords="word counter, character counter, sentence counter, paragraph counter, reading time calculator, speaking time, text statistics, word count tool"
>
	<div class="max-w-4xl" x-data="wordCounterApp()">
		<h1 class="text-2xl font-bold text-zinc-900 mb-2">Word Counter</h1>
		<p class="text-zinc-600 mb-8">Paste or type your text below to instantly count words, characters, sentences, paragraphs, and more.</p>

		<!-- Textarea -->
		<div class="mb-6">
			<div class="flex items-center justify-between mb-2">
				<label class="text-sm font-medium text-zinc-700">Your Text</label>
				<button
					@click="clearText()"
					x-show="text.length > 0"
					style="display:none;"
					class="text-xs text-zinc-400 hover:text-red-500 transition-colors font-medium"
				>
					Clear
				</button>
			</div>
			<textarea
				x-model="text"
				@input="analyze()"
				rows="12"
				placeholder="Start typing or paste your text here..."
				class="w-full px-4 py-3 border border-zinc-300 rounded-xl text-sm text-zinc-800 leading-relaxed focus:outline-none focus:ring-2 focus:ring-zinc-400 resize-y font-sans bg-white transition-shadow"
				id="wc-textarea"
			></textarea>
		</div>

		<!-- Stats Grid -->
		<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 mb-6">

			<!-- Words -->
			<div class="bg-white border border-zinc-200 rounded-xl p-4 flex flex-col gap-1 hover:border-zinc-300 hover:shadow-sm transition-all">
				<span class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Words</span>
				<span class="text-3xl font-bold text-zinc-900" x-text="stats.words.toLocaleString()">0</span>
			</div>

			<!-- Characters (with spaces) -->
			<div class="bg-white border border-zinc-200 rounded-xl p-4 flex flex-col gap-1 hover:border-zinc-300 hover:shadow-sm transition-all">
				<span class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Characters</span>
				<span class="text-3xl font-bold text-zinc-900" x-text="stats.characters.toLocaleString()">0</span>
				<span class="text-xs text-zinc-400">with spaces</span>
			</div>

			<!-- Characters (no spaces) -->
			<div class="bg-white border border-zinc-200 rounded-xl p-4 flex flex-col gap-1 hover:border-zinc-300 hover:shadow-sm transition-all">
				<span class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Characters</span>
				<span class="text-3xl font-bold text-zinc-900" x-text="stats.charsNoSpace.toLocaleString()">0</span>
				<span class="text-xs text-zinc-400">no spaces</span>
			</div>

			<!-- Sentences -->
			<div class="bg-white border border-zinc-200 rounded-xl p-4 flex flex-col gap-1 hover:border-zinc-300 hover:shadow-sm transition-all">
				<span class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Sentences</span>
				<span class="text-3xl font-bold text-zinc-900" x-text="stats.sentences.toLocaleString()">0</span>
			</div>

			<!-- Paragraphs -->
			<div class="bg-white border border-zinc-200 rounded-xl p-4 flex flex-col gap-1 hover:border-zinc-300 hover:shadow-sm transition-all">
				<span class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Paragraphs</span>
				<span class="text-3xl font-bold text-zinc-900" x-text="stats.paragraphs.toLocaleString()">0</span>
			</div>

			<!-- Lines -->
			<div class="bg-white border border-zinc-200 rounded-xl p-4 flex flex-col gap-1 hover:border-zinc-300 hover:shadow-sm transition-all">
				<span class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Lines</span>
				<span class="text-3xl font-bold text-zinc-900" x-text="stats.lines.toLocaleString()">0</span>
			</div>

			<!-- Spaces -->
			<div class="bg-white border border-zinc-200 rounded-xl p-4 flex flex-col gap-1 hover:border-zinc-300 hover:shadow-sm transition-all">
				<span class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Spaces</span>
				<span class="text-3xl font-bold text-zinc-900" x-text="stats.spaces.toLocaleString()">0</span>
			</div>

			<!-- Unique Words -->
			<div class="bg-white border border-zinc-200 rounded-xl p-4 flex flex-col gap-1 hover:border-zinc-300 hover:shadow-sm transition-all">
				<span class="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Unique Words</span>
				<span class="text-3xl font-bold text-zinc-900" x-text="stats.uniqueWords.toLocaleString()">0</span>
			</div>
		</div>

		<!-- Reading & Speaking Time -->
		<div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
			<div class="bg-zinc-900 text-white rounded-xl p-5 flex items-center gap-4">
				<div class="flex-shrink-0 w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center">
					<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
					</svg>
				</div>
				<div>
					<p class="text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-0.5">Reading Time</p>
					<p class="text-xl font-bold" x-text="stats.readingTime">0 sec</p>
					<p class="text-xs text-zinc-500 mt-0.5">avg. 238 wpm</p>
				</div>
			</div>

			<div class="bg-zinc-800 text-white rounded-xl p-5 flex items-center gap-4">
				<div class="flex-shrink-0 w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center">
					<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/>
					</svg>
				</div>
				<div>
					<p class="text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-0.5">Speaking Time</p>
					<p class="text-xl font-bold" x-text="stats.speakingTime">0 sec</p>
					<p class="text-xs text-zinc-500 mt-0.5">avg. 150 wpm</p>
				</div>
			</div>
		</div>

		<!-- Top Keywords -->
		<div x-show="stats.words > 0" style="display:none;" class="mb-8">
			<h2 class="text-sm font-semibold text-zinc-700 mb-3">Top Keywords</h2>
			<div class="flex flex-wrap gap-2">
				<template x-for="kw in stats.topKeywords" :key="kw.word">
					<span class="inline-flex items-center gap-1.5 bg-zinc-100 text-zinc-700 text-xs px-3 py-1.5 rounded-full border border-zinc-200">
						<span class="font-medium" x-text="kw.word"></span>
						<span class="text-zinc-400" x-text="'×' + kw.count"></span>
					</span>
				</template>
			</div>
		</div>

		<!-- Empty state -->
		<div x-show="stats.words === 0" class="text-center py-12 text-zinc-400">
			<svg xmlns="http://www.w3.org/2000/svg" class="mx-auto mb-3 w-10 h-10 text-zinc-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
				<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
			</svg>
			<p class="text-sm">Statistics will appear as you type</p>
		</div>
	</div>

	<script is:inline>
		document.addEventListener('alpine:init', () => {
			Alpine.data('wordCounterApp', () => ({
				text: '',
				stats: {
					words: 0,
					characters: 0,
					charsNoSpace: 0,
					sentences: 0,
					paragraphs: 0,
					lines: 0,
					spaces: 0,
					uniqueWords: 0,
					readingTime: '0 sec',
					speakingTime: '0 sec',
					topKeywords: [],
				},

				init() {
					this.analyze();
				},

				clearText() {
					this.text = '';
					this.analyze();
				},

				formatTime(minutes) {
					if (minutes < 1) {
						const secs = Math.round(minutes * 60);
						if (secs === 0) return '0 sec';
						return secs + ' sec';
					}
					const mins = Math.floor(minutes);
					const secs = Math.round((minutes - mins) * 60);
					if (secs === 0) return mins + ' min';
					return mins + ' min ' + secs + ' sec';
				},

				analyze() {
					const t = this.text;

					// Characters
					const characters = t.length;
					const charsNoSpace = t.replace(/ /g, '').length;
					const spaces = t.split('').filter(c => c === ' ').length;

					// Words
					const wordMatches = t.trim() === '' ? [] : t.trim().split(/\s+/).filter(w => w.length > 0);
					const wordCount = wordMatches.length;

					// Unique words
					const stopWords = new Set(['the','a','an','and','or','but','in','on','at','to','for','of','with','by','from','is','was','are','were','be','been','has','have','had','do','does','did','will','would','could','should','may','might','shall','can','this','that','these','those','it','its','i','we','you','he','she','they','me','us','him','her','them','my','our','your','his','her','their','not','no','so','if','as','than','then','when','where','who','what','how','all','any','both','each','few','more','most','other','some','such','each','every','either','neither','much','many']);
					const cleanWords = wordMatches.map(w => w.toLowerCase().replace(/[^a-z0-9]/g, '')).filter(w => w.length > 1);
					const uniqueWords = new Set(cleanWords).size;

					// Sentences — split on . ! ? followed by space or end
					const sentenceMatches = t.trim() === '' ? [] : t.split(/[.!?]+/).filter(s => s.trim().length > 0);
					const sentences = sentenceMatches.length;

					// Paragraphs — split on double newlines
					const paragraphMatches = t.trim() === '' ? [] : t.split(/\n\s*\n/).filter(p => p.trim().length > 0);
					const paragraphs = paragraphMatches.length;

					// Lines
					const lines = t === '' ? 0 : t.split('\n').length;

					// Reading time (avg 238 wpm)
					const readingMinutes = wordCount / 238;
					const readingTime = this.formatTime(readingMinutes);

					// Speaking time (avg 150 wpm)
					const speakingMinutes = wordCount / 150;
					const speakingTime = this.formatTime(speakingMinutes);

					// Top keywords (exclude stopwords, min 2 chars)
					const freq = {};
					for (const w of cleanWords) {
						if (!stopWords.has(w) && w.length >= 2) {
							freq[w] = (freq[w] || 0) + 1;
						}
					}
					const topKeywords = Object.entries(freq)
						.sort((a, b) => b[1] - a[1])
						.slice(0, 12)
						.map(([word, count]) => ({ word, count }));

					this.stats = {
						words: wordCount,
						characters,
						charsNoSpace,
						sentences,
						paragraphs,
						lines,
						spaces,
						uniqueWords,
						readingTime,
						speakingTime,
						topKeywords,
					};
				},
			}));
		});
	</script>
</Layout>
