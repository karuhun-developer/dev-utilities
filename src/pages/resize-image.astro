---
import Layout from '../layouts/Layout.astro';
---

<Layout 
	title="Image Resizer"
	description="Resize images instantly in your browser without uploading to a server. Change width, height, and maintain aspect ratio easily."
	keywords="image resizer, resize image online, change image dimensions, online photo resizer, client side image processing, dev tools"
>
	<div class="max-w-6xl" x-data="imageResizerApp()">
		<h1 class="text-2xl font-bold text-zinc-900 mb-2">Image Resizer</h1>
		<p class="text-zinc-600 mb-8">Change the dimensions of your images quickly and securely. Processing is done entirely in your browser.</p>

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
			
			<!-- Input Section -->
			<div class="space-y-6">
				<div class="space-y-4">
					<label class="block text-sm font-medium text-zinc-700">Upload Original Image</label>
					<div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-zinc-300 border-dashed rounded-lg hover:bg-zinc-50 transition-colors relative">
						<div class="space-y-1 text-center">
							<svg class="mx-auto h-12 w-12 text-zinc-400" stroke="currentColor" fill="none" viewBox="0 0 48 48" aria-hidden="true">
								<path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
							<div class="flex text-sm text-zinc-600 justify-center">
								<label for="file-upload" class="relative cursor-pointer bg-white rounded-md font-medium text-blue-600 hover:text-blue-500 focus-within:outline-none focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-blue-500">
									<span>Upload a file</span>
									<input id="file-upload" type="file" accept="image/*" class="sr-only" @change="handleFileUpload">
								</label>
								<p class="pl-1">or drag and drop</p>
							</div>
							<p class="text-xs text-zinc-500">PNG, JPG, WEBP, GIF up to 10MB</p>
						</div>
					</div>
				</div>

				<div x-show="originalImageSrc" style="display: none;" class="space-y-4 bg-zinc-50 p-4 border border-zinc-200 rounded-lg">
					<div class="flex items-center justify-between">
						<span class="text-sm font-medium text-zinc-700">Original Preview:</span>
						<span class="text-xs font-mono bg-zinc-200 text-zinc-700 px-2 py-1 rounded" x-text="originalWidth + ' x ' + originalHeight + ' px'"></span>
					</div>
					<div class="flex justify-center bg-white border border-zinc-200 rounded p-2">
						<img :src="originalImageSrc" class="max-h-64 object-contain" alt="Original Image Preview">
					</div>
				</div>
			</div>

			<!-- Output Settings & Preview -->
			<div class="space-y-6">
				<div class="bg-zinc-50 p-6 border border-zinc-200 rounded-lg space-y-4">
					<h3 class="text-sm font-bold text-zinc-900 border-b border-zinc-200 pb-2">Resize Settings</h3>
					
					<div class="flex items-center space-x-2">
						<input type="checkbox" id="maintainAspectRatio" x-model="maintainAspectRatio" class="rounded text-zinc-900 focus:ring-zinc-900 border-zinc-300">
						<label for="maintainAspectRatio" class="text-sm text-zinc-700">Maintain Aspect Ratio</label>
					</div>

					<div class="grid grid-cols-2 gap-4">
						<div>
							<label class="block text-sm font-medium text-zinc-700 mb-1">Width (px)</label>
							<input type="number" x-model.number="targetWidth" @input="updateHeight" min="1" class="w-full px-3 py-2 border border-zinc-300 rounded-md shadow-sm focus:outline-none focus:ring-zinc-500 focus:border-zinc-500 sm:text-sm bg-white">
						</div>
						<div>
							<label class="block text-sm font-medium text-zinc-700 mb-1">Height (px)</label>
							<input type="number" x-model.number="targetHeight" @input="updateWidth" min="1" class="w-full px-3 py-2 border border-zinc-300 rounded-md shadow-sm focus:outline-none focus:ring-zinc-500 focus:border-zinc-500 sm:text-sm bg-white">
						</div>
					</div>

					<div class="pt-2">
						<button @click="resizeImage" :disabled="!originalImageSrc || isProcessing" :class="(!originalImageSrc || isProcessing) ? 'opacity-50 cursor-not-allowed' : 'hover:bg-zinc-800'" class="w-full bg-zinc-900 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors flex justify-center items-center">
							<span x-show="!isProcessing">Resize Image</span>
							<span x-show="isProcessing" class="flex items-center" style="display: none;">
								<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
								Resizing...
							</span>
						</button>
					</div>
				</div>

				<div x-show="resizedImageSrc" style="display: none;" class="space-y-4 bg-zinc-50 p-4 border border-zinc-200 rounded-lg">
					<div class="flex items-center justify-between">
						<span class="text-sm font-medium text-zinc-700">Resized Image:</span>
						<div class="space-x-2 flex items-center">
							<span class="text-xs font-mono bg-zinc-200 text-zinc-700 px-2 py-1 rounded" x-text="finalWidth + ' x ' + finalHeight + ' px'"></span>
							<a :href="resizedImageSrc" :download="downloadFilename" class="px-3 py-1.5 bg-blue-600 text-white rounded text-xs font-medium hover:bg-blue-700 transition-colors">
								Download
							</a>
						</div>
					</div>
					<div class="flex justify-center bg-white border border-zinc-200 rounded p-2 relative">
						<img :src="resizedImageSrc" class="max-h-64 object-contain" alt="Resized Image">
					</div>
				</div>
			</div>
		</div>

		<!-- Hidden Canvas for processing -->
		<canvas id="resizeCanvas" style="display: none;"></canvas>
	</div>

	<script is:inline>
		document.addEventListener('alpine:init', () => {
			Alpine.data('imageResizerApp', () => ({
				originalImageSrc: '',
				originalFilename: 'image',
				originalMimeType: 'image/jpeg',
				
				originalWidth: 0,
				originalHeight: 0,
				aspectRatio: 1,

				targetWidth: 0,
				targetHeight: 0,
				maintainAspectRatio: true,
				
				resizedImageSrc: '',
				finalWidth: 0,
				finalHeight: 0,
				isProcessing: false,

				get downloadFilename() {
					const baseName = this.originalFilename.replace(/\.[^/.]+$/, "");
					let ext = 'jpg';
					if (this.originalMimeType === 'image/png') ext = 'png';
					if (this.originalMimeType === 'image/webp') ext = 'webp';
					return `${baseName}-resized.${ext}`;
				},

				handleFileUpload(e) {
					const file = e.target.files[0];
					if (!file) return;

					this.originalFilename = file.name;
					this.originalMimeType = file.type || 'image/jpeg';
					
					const reader = new FileReader();
					reader.onload = (event) => {
						const src = event.target.result;
						this.originalImageSrc = src;
						this.resizedImageSrc = ''; // clear previous
						
						// Load image to get original dimensions
						const img = new Image();
						img.onload = () => {
							this.originalWidth = img.width;
							this.originalHeight = img.height;
							this.targetWidth = img.width;
							this.targetHeight = img.height;
							this.aspectRatio = img.width / img.height;
						};
						img.src = src;
					};
					reader.readAsDataURL(file);
				},

				updateHeight() {
					if (this.maintainAspectRatio && this.targetWidth > 0) {
						this.targetHeight = Math.round(this.targetWidth / this.aspectRatio);
					}
				},

				updateWidth() {
					if (this.maintainAspectRatio && this.targetHeight > 0) {
						this.targetWidth = Math.round(this.targetHeight * this.aspectRatio);
					}
				},

				resizeImage() {
					if (!this.originalImageSrc || this.isProcessing) return;
					if (this.targetWidth <= 0 || this.targetHeight <= 0) {
						alert("Width and height must be greater than 0");
						return;
					}
					
					this.isProcessing = true;
					this.resizedImageSrc = '';

					// Small timeout to allow UI to update to loading state
					setTimeout(() => {
						const img = new Image();
						img.onload = () => {
							try {
								const canvas = document.getElementById('resizeCanvas');
								const ctx = canvas.getContext('2d');
								
								canvas.width = this.targetWidth;
								canvas.height = this.targetHeight;
								
								// Draw with new dimensions
								ctx.drawImage(img, 0, 0, this.targetWidth, this.targetHeight);

								// Output as same mime type as original (default to 0.9 quality if jpeg/webp)
								const dataUrl = canvas.toDataURL(this.originalMimeType, 0.9);
								
								this.resizedImageSrc = dataUrl;
								this.finalWidth = this.targetWidth;
								this.finalHeight = this.targetHeight;
							} catch (e) {
								console.error("Error resizing image:", e);
								alert("Failed to resize image.");
							} finally {
								this.isProcessing = false;
							}
						};
						img.onerror = () => {
							alert("Error loading image for resizing.");
							this.isProcessing = false;
						};
						img.src = this.originalImageSrc;
					}, 50);
				}
			}));
		});
	</script>
</Layout>
