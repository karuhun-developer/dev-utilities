---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="QR Code Generator"
	description="Generate QR codes instantly from any text or URL in your browser. Customize size, colors, and error correction level. Download as PNG for free."
	keywords="qr code generator, qr generator online, create qr code, qr code from url, free qr code maker"
>
	<div class="max-w-4xl" x-data="qrGeneratorApp()">
		<h1 class="text-2xl font-bold text-zinc-900 mb-2">QR Code Generator</h1>
		<p class="text-zinc-600 mb-8">Generate QR codes from any text or URL. Customize size, colors, and download as PNG.</p>

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

			<!-- Settings -->
			<div class="space-y-5">
				<div>
					<label class="block text-sm font-medium text-zinc-700 mb-1">Text / URL</label>
					<textarea
						x-model="inputText"
						@input="debouncedGenerate()"
						rows="4"
						placeholder="https://karuhundeveloper.com"
						class="w-full px-3 py-2 border border-zinc-300 rounded-md text-sm font-mono focus:outline-none focus:ring-1 focus:ring-zinc-500 resize-none"
					></textarea>
				</div>

				<div class="grid grid-cols-2 gap-4">
					<div>
						<label class="block text-sm font-medium text-zinc-700 mb-1">Size (px)</label>
						<input type="number" x-model.number="size" @change="generate()" min="64" max="1024" step="8"
							class="w-full px-3 py-2 border border-zinc-300 rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-zinc-500">
					</div>
					<div>
						<label class="block text-sm font-medium text-zinc-700 mb-1">Error Correction</label>
						<select x-model="errorLevel" @change="generate()" class="w-full px-3 py-2 border border-zinc-300 rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-zinc-500 bg-white">
							<option value="L">L — Low (7%)</option>
							<option value="M">M — Medium (15%)</option>
							<option value="Q">Q — Quartile (25%)</option>
							<option value="H">H — High (30%)</option>
						</select>
					</div>
				</div>

				<div class="grid grid-cols-2 gap-4">
					<div>
						<label class="block text-sm font-medium text-zinc-700 mb-1">Foreground</label>
						<div class="flex gap-2 items-center">
							<input type="color" x-model="fgColor" @change="generate()" class="h-9 w-14 border border-zinc-300 rounded cursor-pointer">
							<input type="text" x-model="fgColor" @change="generate()" class="flex-1 px-2 py-2 border border-zinc-300 rounded-md text-sm font-mono focus:outline-none focus:ring-1 focus:ring-zinc-500">
						</div>
					</div>
					<div>
						<label class="block text-sm font-medium text-zinc-700 mb-1">Background</label>
						<div class="flex gap-2 items-center">
							<input type="color" x-model="bgColor" @change="generate()" class="h-9 w-14 border border-zinc-300 rounded cursor-pointer">
							<input type="text" x-model="bgColor" @change="generate()" class="flex-1 px-2 py-2 border border-zinc-300 rounded-md text-sm font-mono focus:outline-none focus:ring-1 focus:ring-zinc-500">
						</div>
					</div>
				</div>

				<div class="flex gap-3 items-center pt-1">
					<button
						@click="download()"
						:disabled="!qrDataUrl"
						:class="!qrDataUrl ? 'opacity-50 cursor-not-allowed' : 'hover:bg-zinc-800'"
						class="bg-zinc-900 text-white px-5 py-2 rounded-md text-sm font-medium transition-colors"
					>
						Download PNG
					</button>
					<button @click="reset()" class="text-sm text-zinc-500 hover:text-zinc-800 transition-colors">Reset</button>
				</div>
			</div>

			<!-- Preview -->
			<div class="flex flex-col items-center justify-center bg-zinc-50 border border-zinc-200 rounded-lg p-6 min-h-[360px]">
				<div x-show="qrDataUrl" style="display:none;" class="flex flex-col items-center gap-4">
					<img :src="qrDataUrl" alt="QR Code" class="rounded shadow-sm max-w-full">
					<p class="text-xs text-zinc-400 text-center break-all max-w-xs" x-text="inputText.length > 60 ? inputText.substring(0, 60) + '...' : inputText"></p>
				</div>
				<div x-show="errorMsg" class="text-sm text-red-500 text-center" x-text="errorMsg" style="display:none;"></div>
				<div x-show="!qrDataUrl && !errorMsg" class="text-sm text-zinc-400 italic text-center">
					Type anything above — QR code will appear here automatically
				</div>
			</div>
		</div>

		<canvas id="qr-canvas" style="display:none;"></canvas>
	</div>

	<script is:inline>
		// Load QRCode lib immediately, before Alpine initializes
		window.__qrLoaded = new Promise((resolve, reject) => {
			const s = document.createElement('script');
			s.src = 'https://cdn.jsdelivr.net/npm/qrcode/build/qrcode.min.js';
			s.onload = resolve;
			s.onerror = () => {
				// fallback to unpkg
				const s2 = document.createElement('script');
				s2.src = 'https://unpkg.com/qrcode/build/qrcode.min.js';
				s2.onload = resolve;
				s2.onerror = reject;
				document.head.appendChild(s2);
			};
			document.head.appendChild(s);
		});

		document.addEventListener('alpine:init', () => {
			Alpine.data('qrGeneratorApp', () => ({
				inputText: 'https://karuhundeveloper.com',
				size: 256,
				errorLevel: 'M',
				fgColor: '#18181b',
				bgColor: '#ffffff',
				qrDataUrl: '',
				errorMsg: '',
				_timer: null,

				async init() {
					// Wait for lib then auto-generate
					await window.__qrLoaded;
					this.generate();
				},

				debouncedGenerate() {
					clearTimeout(this._timer);
					this._timer = setTimeout(() => this.generate(), 300);
				},

				async generate() {
					if (!this.inputText.trim()) {
						this.qrDataUrl = '';
						this.errorMsg = '';
						return;
					}
					await window.__qrLoaded;
					try {
						this.errorMsg = '';
						const canvas = document.getElementById('qr-canvas');
						await QRCode.toCanvas(canvas, this.inputText, {
							width: this.size,
							margin: 2,
							errorCorrectionLevel: this.errorLevel,
							color: { dark: this.fgColor, light: this.bgColor }
						});
						this.qrDataUrl = canvas.toDataURL('image/png');
					} catch(e) {
						this.errorMsg = 'Error: ' + e.message;
						this.qrDataUrl = '';
					}
				},

				download() {
					if (!this.qrDataUrl) return;
					const a = document.createElement('a');
					a.href = this.qrDataUrl;
					a.download = 'qrcode.png';
					a.click();
				},

				reset() {
					this.inputText = '';
					this.qrDataUrl = '';
					this.errorMsg = '';
				}
			}));
		});
	</script>
</Layout>
